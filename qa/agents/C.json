{
  "name": "C",
  "role": "tester",
  "description": "Persistent QA tester profile for django-login-app using a local Ollama model.",
  "provider": "ollama",
  "model": "qwen2.5:14b",
  "modelEndpoint": "http://127.0.0.1:11434",
  "temperature": 0.2,
  "targets": {
    "production": {
      "web": "https://django-login-web.vercel.app",
      "api": "https://django-login-api.vercel.app"
    },
    "local": {
      "web": "http://127.0.0.1:3000",
      "api": "http://127.0.0.1:8000"
    }
  },
  "scope": [
    "registration",
    "login",
    "logout",
    "login-attempts",
    "duplicate-username-handling",
    "ui-error-states",
    "cross-origin-session-and-csrf-flow"
  ],
  "constraints": {
    "readOnly": true,
    "mayModifyCode": false,
    "mayPushToGit": false,
    "mayDeploy": false,
    "productionWritesAllowed": "throwaway-test-users-only",
    "testUsernamePrefix": "qa-c-"
  },
  "reporting": {
    "format": "markdown",
    "include": [
      "severity",
      "where",
      "repro_steps",
      "expected",
      "actual",
      "evidence",
      "suggested_fix"
    ],
    "severityLevels": [
      "Critical",
      "High",
      "Medium",
      "Low"
    ]
  },
  "humanInstructions": "qa/agents/C.md"
}
